{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "mkdir -p .vercel_out && cp public/index.html .vercel_out/index.html",
  "outputDirectory": ".vercel_out",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "destination": "http://201.51.5.121:8000/:path*",
      "permanent": false
    }
  ]
}
